# Host-side port assignments for the portfolio stack.
# The parent Makefile includes and exports these so every submodule compose
# and local-dev target picks them up from the shell environment.
#
# Override any value by exporting it before running make:
#   PORTFOLIO_PORT=4000 make docker-frontend-up
#
# Submodule docker-compose files keep their own defaults (e.g. 3000, 3306)
# as fallbacks for standalone use. When running through the parent Makefile,
# these values take precedence.

PORTFOLIO_PORT              ?= 3100
PORTFOLIO_BFF_PORT          ?= 8001
PORTFOLIO_BFF_DB_PORT       ?= 3307
PORTFOLIO_BFF_ADMIN_UI_PORT ?= 3001
CALENDAR_API_PORT           ?= 8002
